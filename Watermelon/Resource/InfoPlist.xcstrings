    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon verwendet die Geräteauthentifizierung, um gespeicherte Server-Zugangsdaten anzuzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon uses device authentication to reveal saved server credentials."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon usa la autenticación del dispositivo para mostrar las credenciales de servidor guardadas."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon usa la autenticación del dispositivo para mostrar las credenciales de servidor guardadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon utilise l’authentification de l’appareil pour afficher les identifiants de serveur enregistrés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelonは、保存済みサーバー認証情報を表示するためにデバイス認証を使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon은 저장된 서버 자격 증명을 표시하기 위해 기기 인증을 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Watermelon usa a autenticação do dispositivo para mostrar credenciais de servidor salvas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Watermelon usa a autenticação do dispositivo para mostrar credenciais de servidor guardadas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon использует аутентификацию устройства, чтобы показать сохранённые учётные данные сервера."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon використовує автентифікацію пристрою, щоб показати збережені облікові дані сервера."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon 使用设备认证来显示已保存的服务器凭据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon 會使用裝置認證來顯示已儲存的伺服器憑據。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon 會使用裝置認證來顯示已儲存的伺服器憑據。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription" : {
      "comment" : "Privacy - Local Network Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup nutzt Ihr lokales Netzwerk, um eine Verbindung zu SMB-Servern herzustellen und Ihre Fotos zu sichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon Backup uses your local network to connect to SMB servers and back up your photos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía usa tu red local para conectarse a servidores SMB y hacer copias de seguridad de tus fotos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía usa tu red local para conectarse a servidores SMB y respaldar tus fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup utilise votre réseau local pour se connecter aux serveurs SMB et sauvegarder vos photos."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スイカバックアップは SMB サーバーに接続して写真をバックアップするためにローカルネットワークを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "수박 백업은 SMB 서버에 연결하여 사진을 백업하기 위해 로컬 네트워크를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia usa sua rede local para conectar a servidores SMB e fazer backup das suas fotos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia usa a sua rede local para ligar a servidores SMB e fazer cópia de segurança das suas fotos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Арбуз Backup использует локальную сеть для подключения к SMB-серверам и резервного копирования ваших фото."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кавун Backup використовує вашу локальну мережу для підключення до SMB-серверів та резервного копіювання фотографій."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜备份使用本地网络连接 SMB 服务器并备份你的照片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜備份使用本機網路連接 SMB 伺服器並備份你的照片。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜備份使用本機網路連接 SMB 伺服器並備份你的相片。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup schreibt nur dann in deine Fotomediathek, wenn du Fotos oder Videos aus einer Sicherung wiederherstellst, und fügt die ausgewählten Elemente wieder zur Fotos-App hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon Backup writes to your photo library only when you restore photos or videos from a backup, placing the selected items back into the Photos app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía solo escribe en tu fototeca cuando restauras fotos o vídeos desde una copia de seguridad, devolviendo los elementos seleccionados a la app Fotos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía solo escribe en tu fototeca cuando restauras fotos o videos desde un respaldo, devolviendo los elementos seleccionados a la app Fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup n'écrit dans votre photothèque que lorsque vous restaurez des photos ou des vidéos depuis une sauvegarde, pour ajouter à nouveau les éléments sélectionnés dans l'app Photos."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バックアップから写真や動画を復元する場合にのみ、スイカバックアップは写真ライブラリに書き込み、選択した項目を「写真」Appに戻します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "수박 백업은 백업에서 사진이나 동영상을 복원할 때에만 사진 라이브러리에 기록하여 선택한 항목을 사진 앱에 다시 추가합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia só grava na sua biblioteca de fotos quando você restaura fotos ou vídeos a partir de um backup, devolvendo os itens selecionados ao app Fotos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia só escreve na sua biblioteca de fotos quando restaura fotos ou vídeos a partir de uma cópia de segurança, colocando novamente os itens selecionados na app Fotos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Арбуз Backup записывает данные в вашу медиатеку только при восстановлении фото или видео из резервной копии — выбранные элементы возвращаются обратно в приложение «Фото»."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кавун Backup записує до фотобібліотеки лише під час відновлення фотографій або відео з резервної копії, повертаючи обрані елементи до програми «Фото»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅当你从备份中还原照片或视频时，西瓜备份才会写入你的照片图库，把所选内容重新加入「照片」App。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅當你從備份還原照片或影片時，西瓜備份才會寫入你的照片圖庫，將所選項目重新加入「照片」App。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅當你從備份還原相片或影片時，西瓜備份才會寫入你的相片圖庫，將所選項目重新加入「相片」App。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup liest deine Fotos und Videos, um die Originale auf den von dir eingerichteten SMB-Server, WebDAV-Server oder ein externes Speichergerät zu sichern. Deine Dateien werden niemals auf die Server von Melon Backup hochgeladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon Backup reads your photos and videos to back up the originals to the SMB server, WebDAV server, or external drive you set up. Your files are never uploaded to Watermelon Backup's servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía lee tus fotos y vídeos para hacer una copia de seguridad de los originales en el servidor SMB, servidor WebDAV o unidad externa que tú configures. Tus archivos nunca se envían a los servidores de Backup Sandía."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía lee tus fotos y videos para respaldar los originales en el servidor SMB, servidor WebDAV o unidad externa que tú configures. Tus archivos nunca se envían a los servidores de Backup Sandía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melon Backup lit vos photos et vidéos afin de sauvegarder les originaux sur le serveur SMB, le serveur WebDAV ou le support de stockage externe que vous configurez. Vos fichiers ne sont jamais envoyés aux serveurs de Melon Backup."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スイカバックアップは、ご自身で設定されたSMBサーバ、WebDAVサーバ、または外付けストレージに写真と動画のオリジナルをバックアップするためにライブラリを読み取ります。ファイルがスイカバックアップのサーバに送信されることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "수박 백업은 사용자가 직접 설정한 SMB 서버, WebDAV 서버 또는 외장 저장 장치로 원본 사진과 동영상을 백업하기 위해 라이브러리를 읽습니다. 파일은 수박 백업의 서버로 업로드되지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia lê suas fotos e vídeos para fazer backup dos originais no servidor SMB, servidor WebDAV ou unidade externa configurada por você. Seus arquivos nunca são enviados para os servidores do Backup Melancia."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia lê as suas fotos e vídeos para fazer cópias de segurança dos originais no servidor SMB, servidor WebDAV ou unidade externa que configurar. Os seus ficheiros nunca são enviados para os servidores do Backup Melancia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Арбуз Backup читает ваши фото и видео, чтобы создавать резервные копии оригиналов на настроенном вами SMB-сервере, WebDAV-сервере или внешнем накопителе. Файлы никогда не загружаются на серверы Арбуз Backup."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кавун Backup читає ваші фотографії та відео, щоб створювати резервні копії оригіналів на SMB-сервері, WebDAV-сервері або зовнішньому накопичувачі, який ви налаштували. Ваші файли ніколи не надсилаються на сервери Кавун Backup."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜备份会读取你的照片和视频，以便将原始文件备份到你自行配置的 SMB 服务器、WebDAV 服务器或外接存储设备。文件不会上传到西瓜备份的服务器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜備份會讀取你的照片和影片，以便將原始檔案備份至你自行設定的 SMB 伺服器、WebDAV 伺服器或外接儲存裝置。檔案不會上傳至西瓜備份的伺服器。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "西瓜備份會讀取你的相片和影片，以便將原始檔案備份至你自行設定的 SMB 伺服器、WebDAV 伺服器或外接儲存裝置。檔案不會上傳至西瓜備份的伺服器。"
          }
        }
      }
    }
  },
  "version" : "1.1"
}