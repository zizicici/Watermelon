    "backgroundBackup.interval.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist das kürzeste Intervall. Das System bestimmt den tatsächlichen Zeitpunkt und führt die Sicherung nie häufiger aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the shortest interval. The system decides when it actually runs and will never run it more frequently."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como máximo con esta frecuencia. El sistema decide cuándo se ejecuta y nunca con mayor frecuencia."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Como máximo con esta frecuencia. El sistema decide cuándo se ejecuta y nunca con mayor frecuencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Au maximum à cette fréquence. Le système décide du moment réel et jamais plus souvent."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最短でこの間隔です。実際の実行タイミングはシステムが決め、これより頻繁には実行されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최대 이 빈도로 실행됩니다. 실제 실행 시점은 시스템이 정하며 이보다 자주 실행되지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No máximo com esta frequência. O sistema decide quando executa e nunca com mais frequência."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No máximo com esta frequência. O sistema decide quando executa e nunca com mais frequência."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не чаще этого интервала. Система сама решает, когда выполнять, и не делает это чаще."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не частіше за цей інтервал. Система сама вирішує, коли виконувати, і не робить це частіше."
