    "mediaBrowser.action.incompleteDownload.confirmMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Sicherung ist unvollständig. Beim Herunterladen entsteht ein neues, separates Objekt, das nicht zur Sicherung passt und bei einer erneuten Sicherung als neues Objekt gesichert werden kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This backup is incomplete. Downloading creates a new, separate asset that doesn't match the backup and may be backed up again as new."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta copia de seguridad está incompleta. Al descargarla se crea un elemento nuevo e independiente que no coincide con la copia de seguridad y podría volver a incluirse como nuevo en otra copia de seguridad."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este respaldo está incompleto. Al descargarlo se crea un elemento nuevo e independiente que no coincide con el respaldo y podría volver a respaldarse como nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette sauvegarde est incomplète. Le téléchargement crée un nouvel élément distinct qui ne correspond pas à la sauvegarde et pourra être sauvegardé à nouveau en tant que nouvel élément."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このバックアップは不完全です。ダウンロードすると、バックアップと一致しない新しい項目が作成され、今後のバックアップで新しい項目として再びバックアップされる場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 백업은 불완전합니다. 다운로드하면 백업과 일치하지 않는 새 항목이 생성되며 다시 백업하면 새 항목으로 백업될 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este backup está incompleto. Baixar cria um item novo e separado que não corresponde ao backup e pode ser copiado novamente como um item novo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta cópia de segurança está incompleta. Transferir cria um item novo e separado que não corresponde à cópia e pode ser copiado novamente como um item novo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эта резервная копия неполная. При загрузке создаётся новый отдельный объект, который не соответствует копии и может быть снова выгружен как новый объект."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ця резервна копія неповна. Під час завантаження створюється новий окремий об’єкт, який не відповідає копії й може бути знову вивантажений як новий об’єкт."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此备份不完整。下载会创建一个与备份记录不匹配的新项目，并在再次备份时可能作为新项目重新备份。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此備份不完整。下載會建立一個與備份記錄不符的新項目，並在再次備份時可能作為新項目重新備份。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此備份不完整。下載會建立一個與備份記錄不符的新項目，並在再次備份時可能作為新項目重新備份。"
          }
        }
      }
    },
