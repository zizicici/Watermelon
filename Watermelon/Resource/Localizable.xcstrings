    "auth.webdav.footerEdit" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das gespeicherte Passwort wird als ******** angezeigt. Nicht bearbeiten, um es beizubehalten; Eingaben ersetzen es. Leeren Sie das Feld, um ein leeres Passwort zu speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The saved password is shown as ********. Leave it unchanged to keep it; type to replace it. Clear the field to save an empty password."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La contraseña guardada se muestra como ********. No la edites para conservarla; escribe para reemplazarla. Borra el campo para guardar una contraseña vacía."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La contraseña guardada se muestra como ********. No la edites para conservarla; escribe para reemplazarla. Borra el campo para guardar una contraseña vacía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mot de passe enregistré s’affiche sous la forme ********. Ne le modifiez pas pour le conserver ; saisissez une valeur pour le remplacer. Effacez le champ pour enregistrer un mot de passe vide."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存済みのパスワードは ******** と表示されます。変更しなければそのまま使用されます。入力すると置き換わります。空にすると空のパスワードとして保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장된 비밀번호는 ********로 표시됩니다. 그대로 두면 유지되고, 입력하면 교체됩니다. 필드를 비우면 빈 비밀번호로 저장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A senha salva aparece como ********. Não edite para mantê-la; digite para substituí-la. Limpe o campo para salvar uma senha vazia."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A palavra-passe guardada aparece como ********. Não edite para a manter; introduza texto para a substituir. Limpe o campo para guardar uma palavra-passe vazia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохранённый пароль отображается как ********. Не изменяйте его, чтобы сохранить; введите новое значение, чтобы заменить. Очистите поле, чтобы сохранить пустой пароль."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Збережений пароль відображається як ********. Не змінюйте його, щоб зберегти; введіть нове значення, щоб замінити. Очистьте поле, щоб зберегти порожній пароль."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已保存的密码会显示为 ********。不修改会继续使用；输入内容会替换它。清空字段会保存为空密码。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已儲存的密碼會顯示為 ********。不修改會繼續使用；輸入內容會取代它。清空欄位會儲存為空密碼。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已儲存的密碼會顯示為 ********。不修改會繼續使用；輸入內容會取代它。清空欄位會儲存為空密碼。"
          }
        }
      }
    },
    "auth.webdav.footerNew" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der WebDAV-Pfad ist der Mount-Pfad auf dem Server (z. B. /webdav oder /remote.php/dav/…); der Backup-Stammordner ist standardmäßig /Watermelon."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV Path is the mount path on the server (e.g. /webdav or /remote.php/dav/…); the backup root path defaults to /Watermelon."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ruta WebDAV es la ruta de montaje en el servidor (por ejemplo /webdav o /remote.php/dav/…); la ruta raíz de respaldo por defecto es /Watermelon."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ruta WebDAV es la ruta de montaje en el servidor (por ejemplo /webdav o /remote.php/dav/…); la ruta raíz de respaldo por defecto es /Watermelon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le chemin WebDAV est le chemin de montage sur le serveur (ex. /webdav ou /remote.php/dav/…) ; le chemin racine de sauvegarde par défaut est /Watermelon."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV パスはサーバー上のマウントパスです（例：/webdav や /remote.php/dav/…）。バックアップのルートパスのデフォルトは /Watermelon です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 경로는 서버의 마운트 경로입니다 (예: /webdav 또는 /remote.php/dav/…). 백업 루트 경로의 기본값은 /Watermelon입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O caminho WebDAV é o caminho de montagem no servidor (ex.: /webdav ou /remote.php/dav/…); o caminho raiz de backup padrão é /Watermelon."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O caminho WebDAV é o caminho de montagem no servidor (p. ex., /webdav ou /remote.php/dav/…); o caminho raiz de cópia predefinido é /Watermelon."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Путь WebDAV — это путь монтирования на сервере (например, /webdav или /remote.php/dav/…); корневой путь резервных копий по умолчанию /Watermelon."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Шлях WebDAV — це точка монтування на сервері (наприклад, /webdav або /remote.php/dav/…); кореневий шлях резервного копіювання за замовчуванням /Watermelon."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 路径是服务器上的挂载路径（例如 /webdav 或 /remote.php/dav/…）；备份根路径默认为 /Watermelon。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 路徑是伺服器上的掛載路徑（例如 /webdav 或 /remote.php/dav/…）；備份根路徑預設為 /Watermelon。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 路徑是伺服器上的掛載路徑（例如 /webdav 或 /remote.php/dav/…）；備份根路徑預設為 /Watermelon。"
          }
        }
      }
    },
    "auth.webdav.footerServer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP wird nur für Server im lokalen Netzwerk unterstützt. Verwenden Sie HTTPS für DDNS- oder öffentliche Hostnamen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP is supported only for local network servers. Use HTTPS for DDNS or public hostnames."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP solo es compatible con servidores de la red local. Usa HTTPS para DDNS o nombres de host públicos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP solo es compatible con servidores de la red local. Usa HTTPS para DDNS o nombres de host públicos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP est pris en charge uniquement pour les serveurs du réseau local. Utilisez HTTPS pour les noms d’hôte DDNS ou publics."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP はローカルネットワーク上のサーバーでのみサポートされます。DDNS や公開ホスト名には HTTPS を使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP는 로컬 네트워크 서버에서만 지원됩니다. DDNS 또는 공개 호스트 이름에는 HTTPS를 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP só é compatível com servidores da rede local. Use HTTPS para DDNS ou nomes de host públicos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP só é compatível com servidores da rede local. Use HTTPS para DDNS ou nomes de host públicos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP поддерживается только для серверов в локальной сети. Для DDNS или общедоступных имён хостов используйте HTTPS."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP підтримується лише для серверів у локальній мережі. Для DDNS або загальнодоступних імен хостів використовуйте HTTPS."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP 仅支持本地局域网服务器。DDNS 或公网域名请使用 HTTPS。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP 僅支援區域網路中的伺服器。DDNS 或公開網域請使用 HTTPS。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTP 僅支援區域網絡中的伺服器。DDNS 或公開網域請使用 HTTPS。"
          }
        }
      }
    },
