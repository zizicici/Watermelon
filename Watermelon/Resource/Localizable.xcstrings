    "settings.pipProgress.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei Aktivierung zeigt Watermelon ein schwebendes Bild-im-Bild-Fenster mit Live-Protokoll, wenn ein Upload/Download/Sync im Hintergrund läuft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, Watermelon shows a floating Picture-in-Picture window with live log output while an upload, download, or sync is running and the app is in the background."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando se habilita, Watermelon muestra una ventana PiP flotante con registro en vivo durante subidas, descargas o sincronización en segundo plano."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando se habilita, Watermelon muestra una ventana PiP flotante con registro en vivo durante subidas, descargas o sincronización en segundo plano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsqu'activé, Watermelon affiche une fenêtre PiP flottante avec le journal en direct pendant les envois/téléchargements/synchronisations en arrière-plan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、バックグラウンドでアップロード／ダウンロード／同期中にログをリアルタイムで表示するピクチャ・イン・ピクチャウィンドウが浮かびます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 업로드/다운로드/동기화가 백그라운드에서 실행되는 동안 실시간 로그를 표시하는 PiP 창이 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando habilitado, o Watermelon exibe uma janela PiP flutuante com log ao vivo durante upload, download ou sincronização em segundo plano."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando ativado, o Watermelon mostra uma janela PiP flutuante com registo em direto durante upload, download ou sincronização em segundo plano."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли ввімкнено, Watermelon показує плаваюче вікно картинка-в-картинці з журналом у режимі реального часу під час завантаження/вивантаження/синхронізації у фоні."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，当正在上传/下载/同步并切到后台时，悬浮画中画窗口实时显示日志。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，當正在上傳／下載／同步並切到背景時，懸浮子母畫面會即時顯示日誌。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，當正在上傳／下載／同步並切到背景時，懸浮子母畫面會即時顯示日誌。"
          }
        }
      }
