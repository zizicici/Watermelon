    "onboarding.item.dedup.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn dieselbe Foto- oder Videodatei in einem Monat mehrfach vorkommt, behält die Sicherung nur eine Kopie. Lokale und entfernte Anzahlen können dadurch leicht abweichen — das ist normal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the same photo or video appears more than once in a single month, the backup keeps a single copy. Local and remote totals may differ slightly — that's expected."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la misma foto o vídeo aparece más de una vez en un mismo mes, la copia de seguridad conserva una sola copia. Los totales local y remoto pueden diferir ligeramente; es normal."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la misma foto o video aparece más de una vez en un mismo mes, el respaldo conserva una sola copia. Los totales local y remoto pueden diferir ligeramente; es normal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la même photo ou vidéo apparaît plusieurs fois dans le même mois, la sauvegarde n'en garde qu'une copie. Les totaux locaux et distants peuvent légèrement différer, c'est normal."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同じ月の中で同一の写真や動画が複数回現れた場合、バックアップでは 1 つだけ保持します。ローカルとリモートの件数が完全には一致しないことがあるのは、このためです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "같은 달 안에서 동일한 사진이나 동영상이 여러 번 등장하면 백업은 한 개만 보관합니다. 로컬과 원격의 항목 수가 약간 달라지는 것은 정상입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a mesma foto ou vídeo aparecer mais de uma vez no mesmo mês, o backup mantém apenas uma cópia. Os totais local e remoto podem diferir um pouco — isso é esperado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a mesma foto ou vídeo aparecer mais do que uma vez no mesmo mês, o backup mantém apenas uma cópia. Os totais local e remoto podem diferir ligeiramente — isso é esperado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если одно и то же фото или видео встречается в одном месяце более одного раза, в резервной копии остаётся одна копия. Локальный и удалённый итоги могут немного отличаться — это ожидаемо."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо одне й те саме фото або відео з'являється кілька разів за один місяць, у резервній копії залишається лише одна. Тому локальна й віддалена суми можуть трохи відрізнятися — це нормально."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果同一个月里出现完全相同的照片或视频，备份只会保留一份。因此本地与远端的数量可能略有差异，这是正常现象。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果同一個月內出現完全相同的照片或影片，備份只會保留一份。因此，本機與遠端的數量可能略有差異，這是正常現象。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果同一個月內出現完全相同的相片或影片，備份只會保留一份。因此，本機與遠端的數量可能略有差異，這是正常現象。"
          }
        }
      }
    },
    "onboarding.item.dedup.title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppelte Inhalte eines Monats werden nur einmal gespeichert"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duplicates within a month are stored once"
          }
