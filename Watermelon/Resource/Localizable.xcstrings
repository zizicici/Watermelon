    "home.alert.upgradeMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die kostenlose Version unterstützt nur 1 Speicherziel. Upgraden Sie auf Pro für unbegrenzte Speicherziele."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The free version supports only 1 storage target. Upgrade to Pro to unlock unlimited storage targets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La versión gratuita solo admite 1 destino de almacenamiento. Actualice a Pro para desbloquear destinos ilimitados."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
