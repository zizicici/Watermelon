    "auth.external.footerNoDir" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnen Sie in der Dateiauswahl „Durchsuchen“ > „Speicherorte“ und wählen Sie dann Ihr externes Laufwerk oder Ihren mobilen Speicher aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the file picker, open Browse > Locations, then choose your external drive or mobile storage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En el selector de archivos, abre Explorar > Ubicaciones y elige tu unidad externa o almacenamiento móvil."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En el selector de archivos, abre Explorar > Ubicaciones y elige tu unidad externa o almacenamiento móvil."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans le sélecteur de fichiers, choisissez votre disque externe ou stockage mobile dans la liste des emplacements."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ファイルピッカーで「ブラウズ」＞「場所」を開き、外付けドライブまたはモバイルストレージを選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파일 선택기에서 탐색 > 위치를 연 다음 외장 드라이브 또는 모바일 저장소를 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No seletor de arquivos, escolha seu disco externo ou armazenamento móvel na lista de locais."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No seletor de ficheiros, escolha o disco externo ou armazenamento móvel na lista de locais."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В окне выбора файлов выберите внешний диск или мобильное хранилище из списка мест."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У виборі файлів виберіть зовнішній диск або мобільне сховище зі списку місць."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在文件选择器中打开“浏览”>“位置”，选择移动硬盘、U 盘或其他外接存储。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在檔案選擇器中開啟「瀏覽」>「位置」，選擇行動硬碟、USB 隨身碟或其他外接儲存裝置。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在檔案選擇器中開啟「瀏覽」>「位置」，選擇流動硬碟、USB 手指或其他外置儲存裝置。"
          }
        }
      }
    },
    "auth.external.noDirMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
