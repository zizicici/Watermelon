          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La version gratuite ne prend en charge qu'une seule cible de stockage. Passez à Pro pour débloquer des cibles de stockage illimitées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料版はストレージ1つのみ対応です。Pro にアップグレードして無制限のストレージを利用しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무료 버전은 저장소 1개만 지원합니다. Pro로 업그레이드하여 무제한 저장소를 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
