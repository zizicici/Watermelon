    "settings.originalPhotoCacheLimit.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn das Limit erreicht ist, werden die am längsten nicht verwendeten Objekte automatisch entfernt. Wählen Sie „Aus“, um das Zwischenspeichern zu stoppen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the limit is reached, the least-recently-used items are removed automatically. Choose Off to stop caching."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando se alcanza el límite, los elementos menos usados recientemente se eliminan automáticamente. Elige Desactivado para dejar de almacenar en caché."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando se alcanza el límite, los elementos menos usados recientemente se eliminan automáticamente. Elige Desactivado para dejar de almacenar en caché."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque la limite est atteinte, les éléments les moins récemment utilisés sont supprimés automatiquement. Choisissez Désactivé pour arrêter la mise en cache."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上限に達すると、最も長く使われていない項目が自動的に削除されます。キャッシュを停止するには「オフ」を選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한도에 도달하면 가장 오랫동안 사용하지 않은 항목이 자동으로 삭제됩니다. 캐시를 중지하려면 끔을 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o limite é atingido, os itens usados menos recentemente são removidos automaticamente. Escolha Desligado para parar o cache."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o limite é atingido, os itens usados menos recentemente são removidos automaticamente. Escolha Desligado para parar a colocação em cache."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При достижении лимита реже всего используемые элементы удаляются автоматически. Выберите «Выкл.», чтобы прекратить кэширование."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли ліміт досягнуто, елементи, які найдовше не використовувалися, видаляються автоматично. Виберіть «Вимк.», щоб припинити кешування."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "达到上限后，最久未使用的项目会被自动清除。选择「关闭」将不再缓存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "達到上限後，最久未使用的項目會被自動清除。選擇「關閉」將不再快取。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
