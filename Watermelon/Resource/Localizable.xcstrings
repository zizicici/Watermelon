    "home.alert.upgradeMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die kostenlose Version unterstützt nur ein Speicherziel. Mit einem Upgrade auf Pro können Sie unbegrenzt viele Speicherziele verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The free version supports only 1 storage target. Upgrade to Pro to unlock unlimited storage targets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La versión gratuita solo admite un destino de almacenamiento. Actualiza a Pro para desbloquear destinos ilimitados."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La versión gratuita solo admite un destino de almacenamiento. Actualiza a Pro para desbloquear destinos ilimitados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La version gratuite ne prend en charge qu'une seule cible de stockage. Passez à Pro pour débloquer des cibles de stockage illimitées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料版で使用できる保存先は 1 つだけです。Pro にアップグレードすると、保存先を無制限に追加できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무료 버전은 저장소 1개만 지원합니다. Pro로 업그레이드하여 무제한 저장소를 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A versão gratuita suporta apenas 1 destino de armazenamento. Atualize para Pro para desbloquear destinos ilimitados."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A versão gratuita suporta apenas 1 destino de armazenamento. Atualize para Pro para desbloquear destinos ilimitados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бесплатная версия поддерживает только 1 узел хранения. Перейдите на Pro, чтобы снять ограничение."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безкоштовна версія підтримує лише 1 сховище. Оновіть до Pro, щоб розблокувати необмежену кількість сховищ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "免费版仅支持 1 个存储目标。升级 Pro 解锁无限存储目标。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "免費版僅支援 1 個儲存目標。升級 Pro 解鎖無限儲存目標。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
