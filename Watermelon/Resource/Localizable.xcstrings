    "storage.detail.leftover.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restdateien wurden auf den Knoten hochgeladen, aber nie von einem Backup erfasst. Meist sind sie durch ein unterbrochenes Backup entstanden. Es werden nur Dateien aus Monaten aufgeführt, die von dieser App verwaltet werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leftover files were uploaded to the node but never recorded by a backup, usually because a backup was interrupted. Only files in months this app manages are listed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los archivos sobrantes se subieron al nodo pero nunca se registraron en una copia de seguridad, normalmente porque una copia se interrumpió. Solo se muestran archivos de meses que gestiona esta app."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los archivos sobrantes se cargaron en el nodo, pero nunca se registraron en un respaldo, normalmente porque se interrumpió. Solo se muestran archivos de los meses que administra esta app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers résiduels ont été téléversés sur le nœud mais jamais enregistrés par une sauvegarde, généralement à cause d’une sauvegarde interrompue. Seuls les fichiers des mois gérés par cette app sont listés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "残存ファイルはノードにアップロードされたものの、バックアップに記録されていないファイルで、通常はバックアップの中断によって残ります。このアプリが管理対象としている月のファイルだけが表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잔여 파일은 노드에 업로드되었지만 백업에 기록되지 않은 파일로, 보통 백업이 중단되어 발생합니다. 이 앱이 관리하는 월별 폴더의 파일만 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os arquivos residuais foram enviados ao nó, mas nunca registrados por um backup, geralmente porque um backup foi interrompido. Apenas arquivos de meses gerenciados por este app são listados."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os ficheiros residuais foram carregados para o nó, mas nunca registados por uma cópia de segurança, normalmente porque uma cópia foi interrompida. Apenas ficheiros de meses geridos por esta app são listados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Остаточные файлы были загружены на узел, но не записаны резервной копией — обычно из-за прерванного резервного копирования. Показаны только файлы за месяцы, которыми управляет это приложение."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Залишкові файли були завантажені на вузол, але не записані резервною копією — зазвичай через перерване резервне копіювання. Показано лише файли за місяці, якими керує цей застосунок."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "残留文件是已上传到节点、但没有被备份记录的文件，通常由中断的备份造成。仅列出本 App 管理的月份中的文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "殘留檔案是已上傳到節點、但沒有被備份記錄的檔案，通常由中斷的備份造成。僅列出本 App 管理的月份中的檔案。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "殘留檔案是已上載到節點、但沒有被備份記錄的檔案，通常由中斷的備份造成。僅列出本 App 管理月份中的檔案。"
          }
        }
      }
    },
