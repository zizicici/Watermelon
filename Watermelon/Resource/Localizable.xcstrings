          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The existing cache will be deleted and every photo will be rescanned. This can take a while."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminará la caché actual y todas las fotos se volverán a analizar. Puede tardar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
