    "onboarding.item.single_client.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn mehrere Geräte gleichzeitig in denselben Remote-Ordner schreiben, können Inhalte überschrieben oder verloren gehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If two or more devices back up to the same remote folder at once, items can be omitted or overwritten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si dos o más dispositivos hacen una copia de seguridad en la misma carpeta remota a la vez, algunos elementos pueden perderse o sobrescribirse."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si dos o más dispositivos respaldan en la misma carpeta remota a la vez, algunos elementos pueden perderse o sobrescribirse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si deux appareils ou plus sauvegardent simultanément dans le même dossier distant, certains éléments peuvent être écrasés ou perdus."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複数のデバイスが同じリモートフォルダへ同時にバックアップすると、一部のファイルが上書きされたり欠落したりすることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "두 대 이상의 기기가 같은 원격 폴더에 동시에 백업하면 일부 항목이 덮어써지거나 누락될 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se dois ou mais dispositivos fizerem backup na mesma pasta remota ao mesmo tempo, itens podem ser descartados ou sobrescritos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se dois ou mais dispositivos fizerem cópia de segurança na mesma pasta remota ao mesmo tempo, itens podem ser descartados ou sobrescritos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если два или более устройств одновременно делают резервную копию в одну удалённую папку, элементы могут быть пропущены или перезаписаны."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо кілька пристроїв одночасно створюють резервні копії в одній і тій самій віддаленій папці, частина файлів може бути перезаписана або втрачена."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若多台设备同时向同一远端文件夹写入，部分内容可能被覆盖或遗漏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若多台裝置同時向同一遠端資料夾寫入，部分內容可能被覆寫或遺漏。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若多部裝置同時向同一遠端資料夾寫入，部分內容可能被覆寫或遺漏。"
          }
        }
      }
    },
