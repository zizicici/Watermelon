    "auth.smb.discovery.failedToDiscover" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lokale SMB-Dienste konnten nicht gefunden werden. Bitte überprüfen Sie die lokalen Netzwerkberechtigungen oder versuchen Sie es später erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unable to discover local SMB services. Please check local network permissions or try again later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pueden descubrir servicios SMB locales. Verifique los permisos de red local o inténtelo más tarde."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
