    "storage.error.externalUnavailable" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Externer Speicher ist nicht verfügbar. Er wurde möglicherweise getrennt. Bitte schließen Sie das Laufwerk erneut an und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "External storage is unavailable. It may have been disconnected. Please reconnect the drive and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El almacenamiento externo no está disponible. Puede haberse desconectado. Vuelva a conectar la unidad e inténtelo de nuevo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El almacenamiento externo no está disponible. Puede haberse desconectado. Vuelve a conectar la unidad e inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le stockage externe est indisponible. Il a peut-être été déconnecté. Veuillez reconnecter le disque et réessayer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外部ストレージが利用できません。取り外された可能性があります。ドライブを再接続してからもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "외부 저장소를 사용할 수 없습니다. 연결이 해제되었을 수 있습니다. 드라이브를 다시 연결한 후 다시 시도해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O armazenamento externo não está disponível. Ele pode ter sido desconectado. Reconecte a unidade e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O armazenamento externo não está disponível. Pode ter sido desligado. Volte a ligar a unidade e tente novamente."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зовнішнє сховище недоступне. Можливо, воно було від'єднане. Будь ласка, під'єднайте диск знову та спробуйте ще раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接存储不可用，可能已拔出。请重新连接硬盘后再试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接儲存不可用，可能已拔出。請重新連接硬碟後再試。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接儲存不可用，可能已拔出。請重新連接硬碟後再試。"
          }
        }
      }
    },
    "storage.error.smbUnavailable" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die SMB-Verbindung ist nicht verfügbar. Sie wurde möglicherweise getrennt oder hat ein Zeitlimit überschritten. Bitte überprüfen Sie den Netzwerk- und Serverstatus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB connection is unavailable. It may have been disconnected or timed out. Please check the network and server status."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión SMB no está disponible. Puede haberse desconectado o agotado el tiempo. Verifique el estado de la red y del servidor."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión SMB no está disponible. Puede haberse desconectado o agotado el tiempo. Verifica el estado de la red y del servidor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion SMB est indisponible. Elle a peut-être été déconnectée ou a expiré. Veuillez vérifier l'état du réseau et du serveur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 接続が利用できません。切断されたかタイムアウトした可能性があります。ネットワークとサーバーの状態を確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 연결을 사용할 수 없습니다. 연결이 끊어졌거나 시간이 초과되었을 수 있습니다. 네트워크 및 서버 상태를 확인해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conexão SMB não está disponível. Ela pode ter sido desconectada ou expirada. Verifique o status da rede e do servidor."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ligação SMB não está disponível. Pode ter sido desligada ou expirada. Verifique o estado da rede e do servidor."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB-з'єднання недоступне. Можливо, воно було розірване або минув час очікування. Перевірте стан мережі та сервера."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 连接不可用，可能已断开或超时。请检查网络与服务器状态后再试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 連接不可用，可能已斷開或逾時。請檢查網路與伺服器狀態後再試。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 連接不可用，可能已斷開或逾時。請檢查網路與伺服器狀態後再試。"
          }
        }
      }
    },
    "storage.error.webdav401" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV-Authentifizierung fehlgeschlagen (401). Bitte überprüfen Sie Benutzername/Passwort und stellen Sie sicher, dass die Endpoint-URL und der Backup-Stammordner Zugriffsberechtigungen haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV authentication failed (401). Please check the username/password and ensure the Endpoint URL and backup root path have access permissions."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La autenticación WebDAV falló (401). Verifique el nombre de usuario/contraseña y asegúrese de que la URL del Endpoint y la ruta raíz de respaldo tengan permisos de acceso."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La autenticación WebDAV falló (401). Verifica el nombre de usuario/contraseña y asegúrate de que la URL del Endpoint y la ruta raíz de respaldo tengan permisos de acceso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Échec de l'authentification WebDAV (401). Veuillez vérifier le nom d'utilisateur/mot de passe et vous assurer que l'URL du point de terminaison et le chemin racine de sauvegarde ont les permissions d'accès."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 認証に失敗しました（401）。ユーザー名/パスワードを確認し、Endpoint URL とバックアップルートパスにアクセス権限があることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 인증 실패(401). 사용자 이름/비밀번호를 확인하고 Endpoint URL과 백업 루트 경로에 접근 권한이 있는지 확인해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A autenticação WebDAV falhou (401). Verifique o nome de usuário/senha e certifique-se de que a URL do Endpoint e o caminho raiz de backup tenham permissões de acesso."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A autenticação WebDAV falhou (401). Verifique o nome de utilizador/palavra-passe e certifique-se de que o URL do Endpoint e o caminho raiz de cópia têm permissões de acesso."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автентифікація WebDAV не вдалася (401). Перевірте ім'я користувача/пароль та переконайтеся, що URL-адреса Endpoint і кореневий шлях резервного копіювання мають дозволи на доступ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 认证失败（401）。请检查用户名/密码，并确认 Endpoint URL 与备份根路径有访问权限。建议 Endpoint 填 WebDAV 根地址，目录放到「备份根路径」里。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 認證失敗（401）。請檢查使用者名稱/密碼，並確認 Endpoint URL 與備份根路徑有存取權限。建議 Endpoint 填 WebDAV 根地址，目錄放到「備份根路徑」裡。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 認證失敗（401）。請檢查使用者名稱/密碼，並確認 Endpoint URL 與備份根路徑有存取權限。建議 Endpoint 填 WebDAV 根地址，目錄放到「備份根路徑」裡。"
          }
        }
      }
    },
    "storage.error.webdav403" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV-Berechtigung verweigert (403). Bitte stellen Sie sicher, dass das Konto PROPFIND/MKCOL/PUT/MOVE/DELETE-Berechtigungen für den Endpoint und den Backup-Stammordner hat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV permission denied (403). Please ensure the account has PROPFIND/MKCOL/PUT/MOVE/DELETE permissions for the Endpoint and backup root path."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permiso WebDAV denegado (403). Asegúrese de que la cuenta tenga permisos PROPFIND/MKCOL/PUT/MOVE/DELETE para el Endpoint y la ruta raíz de respaldo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permiso WebDAV denegado (403). Asegúrate de que la cuenta tenga permisos PROPFIND/MKCOL/PUT/MOVE/DELETE para el Endpoint y la ruta raíz de respaldo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisation WebDAV refusée (403). Veuillez vous assurer que le compte dispose des permissions PROPFIND/MKCOL/PUT/MOVE/DELETE pour le point de terminaison et le chemin racine de sauvegarde."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV のアクセスが拒否されました（403）。アカウントに Endpoint とバックアップルートパスの PROPFIND/MKCOL/PUT/MOVE/DELETE 権限があることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 권한 거부(403). 해당 계정이 Endpoint 및 백업 루트 경로에 대한 PROPFIND/MKCOL/PUT/MOVE/DELETE 권한을 가지고 있는지 확인해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permissão WebDAV negada (403). Certifique-se de que a conta tenha permissões PROPFIND/MKCOL/PUT/MOVE/DELETE para o Endpoint e o caminho raiz de backup."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permissão WebDAV negada (403). Certifique-se de que a conta tem permissões PROPFIND/MKCOL/PUT/MOVE/DELETE para o Endpoint e o caminho raiz de cópia."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ WebDAV заборонено (403). Переконайтеся, що обліковий запис має дозволи PROPFIND/MKCOL/PUT/MOVE/DELETE для Endpoint та кореневого шляху резервного копіювання."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 权限不足（403）。请确认该账号对 Endpoint 与备份根路径有 PROPFIND/MKCOL/PUT/MOVE/DELETE 权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 權限不足（403）。請確認該帳號對 Endpoint 與備份根路徑有 PROPFIND/MKCOL/PUT/MOVE/DELETE 權限。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WebDAV 權限不足（403）。請確認該帳號對 Endpoint 與備份根路徑有 PROPFIND/MKCOL/PUT/MOVE/DELETE 權限。"
          }
        }
      }
    },
