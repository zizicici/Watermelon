    "storage.error.externalUnavailable" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Externer Speicher ist nicht verfügbar. Er wurde möglicherweise getrennt. Bitte schließen Sie das Laufwerk erneut an und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "External storage is unavailable. It may have been disconnected. Please reconnect the drive and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El almacenamiento externo no está disponible. Puede que se haya desconectado. Vuelve a conectar la unidad e inténtalo de nuevo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El almacenamiento externo no está disponible. Puede haberse desconectado. Vuelve a conectar la unidad e inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le stockage externe est indisponible. Il a peut-être été déconnecté. Veuillez reconnecter le disque et réessayer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外部ストレージが利用できません。取り外された可能性があります。ドライブを再接続してからもう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "외부 저장소를 사용할 수 없습니다. 연결이 해제되었을 수 있습니다. 드라이브를 다시 연결한 후 다시 시도해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O armazenamento externo não está disponível. Ele pode ter sido desconectado. Reconecte a unidade e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O armazenamento externo não está disponível. Pode ter sido desligado. Volte a ligar a unidade e tente novamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Внешний накопитель недоступен. Возможно, он отключён. Подключите устройство и повторите попытку."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зовнішнє сховище недоступне. Можливо, воно було від'єднане. Будь ласка, під'єднайте диск знову та спробуйте ще раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接存储不可用，可能已拔出。请重新连接硬盘后再试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接儲存不可用，可能已拔出。請重新連接硬碟後再試。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外接儲存不可用，可能已拔出。請重新連接硬碟後再試。"
          }
        }
      }
    },
    "storage.error.smbUnavailable" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die SMB-Verbindung ist nicht verfügbar. Sie wurde möglicherweise getrennt oder hat ein Zeitlimit überschritten. Bitte überprüfen Sie den Netzwerk- und Serverstatus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB connection is unavailable. It may have been disconnected or timed out. Please check the network and server status."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión SMB no está disponible. Puede que se haya desconectado o haya agotado el tiempo de espera. Comprueba el estado de la red y del servidor."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión SMB no está disponible. Puede haberse desconectado o agotado el tiempo. Verifica el estado de la red y del servidor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion SMB est indisponible. Elle a peut-être été déconnectée ou a expiré. Veuillez vérifier l'état du réseau et du serveur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 接続が利用できません。切断されたかタイムアウトした可能性があります。ネットワークとサーバーの状態を確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 연결을 사용할 수 없습니다. 연결이 끊어졌거나 시간이 초과되었을 수 있습니다. 네트워크 및 서버 상태를 확인해 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conexão SMB não está disponível. Ela pode ter sido desconectada ou expirada. Verifique o status da rede e do servidor."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ligação SMB não está disponível. Pode ter sido desligada ou expirada. Verifique o estado da rede e do servidor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB-подключение недоступно. Возможно, оно было разорвано или истекло время ожидания. Проверьте сеть и состояние сервера."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB-з'єднання недоступне. Можливо, воно було розірване або минув час очікування. Перевірте стан мережі та сервера."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SMB 连接不可用，可能已断开或超时。请检查网络与服务器状态后再试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
