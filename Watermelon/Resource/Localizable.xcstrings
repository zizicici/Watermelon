    "link.connection.sameNetworkHint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinden Sie beide Geräte mit demselben lokalen Netzwerk. Deaktivieren Sie VPN, falls die Verbindung fehlschlägt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep both devices on the same local network. Turn off VPN if connection fails."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén ambos dispositivos en la misma red local. Desactiva la VPN si falla la conexión."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén ambos dispositivos en la misma red local. Desactiva la VPN si falla la conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez les deux appareils sur le même réseau local. Désactivez le VPN si la connexion échoue."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "両方のデバイスを同じローカルネットワークに接続してください。接続できない場合は VPN をオフにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "두 기기를 같은 로컬 네트워크에 연결하세요. 연결되지 않으면 VPN을 끄세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha os dois dispositivos na mesma rede local. Desative a VPN se a conexão falhar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha os dois dispositivos na mesma rede local. Desative a VPN se a ligação falhar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подключите оба устройства к одной локальной сети. Отключите VPN, если подключение не удаётся."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Підключіть обидва пристрої до однієї локальної мережі. Вимкніть VPN, якщо з’єднання не вдається."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请确保两台设备位于同一局域网；连接失败时可尝试关闭 VPN。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請確保兩部裝置位於同一區域網路；連線失敗時可嘗試關閉 VPN。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請確保兩部裝置連接至同一區域網絡。如果連線失敗，請嘗試關閉 VPN。"
          }
        }
      }
    },
