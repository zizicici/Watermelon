    "home.duplicates.gateExplanation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Duplikaterkennung nutzt den lokalen Index. Der Index ist derzeit unvollständig, sodass einige Duplikate fehlen können. Tippen Sie oben, um den Index aufzubauen oder zu aktualisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duplicate detection relies on the local index. The current index is incomplete, so some duplicates may not appear. Tap above to build or update the index."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La detección de duplicados se basa en el índice local. El índice actual está incompleto, por lo que algunos duplicados pueden no aparecer. Toca arriba para crear o actualizar el índice."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La detección de duplicados se basa en el índice local. El índice actual está incompleto, por lo que algunos duplicados podrían no aparecer. Toca arriba para crear o actualizar el índice."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La détection des doublons repose sur l'index local. L'index actuel est incomplet, donc certains doublons peuvent ne pas apparaître. Touchez ci-dessus pour créer ou mettre à jour l'index."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重複項目の検出はローカルインデックスに依存します。現在のインデックスは不完全なため、一部の重複が表示されないことがあります。上をタップしてインデックスを作成または更新してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "중복 검색은 로컬 인덱스를 사용합니다. 현재 인덱스가 불완전하여 일부 중복 항목이 표시되지 않을 수 있습니다. 위의 항목을 탭하여 인덱스를 생성하거나 업데이트하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A detecção de duplicados depende do índice local. O índice atual está incompleto, portanto alguns duplicados podem não aparecer. Toque acima para criar ou atualizar o índice."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A deteção de duplicados depende do índice local. O índice atual está incompleto, pelo que alguns duplicados podem não aparecer. Toque acima para criar ou atualizar o índice."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поиск дубликатов опирается на локальный индекс. Текущий индекс неполон, поэтому часть дубликатов может не отображаться. Нажмите выше, чтобы построить или обновить индекс."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Виявлення дублікатів спирається на локальний індекс. Поточний індекс неповний, тому деякі дублікати можуть не з’являтися. Торкніться вище, щоб створити або оновити індекс."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重复项目检测依赖本地索引。当前索引尚未完备，可能漏检部分重复项目。轻点上方进入索引页面建立或更新。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重複項目偵測依賴本機索引。目前索引尚未完整，可能會漏掉部分重複項目。點一下上方以開啟索引頁面並建立或更新索引。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重複項目偵測依賴本機索引。目前索引尚未完整，可能會漏掉部分重複項目。點按上方以開啟索引頁面並建立或更新索引。"
          }
        }
      }
    },
