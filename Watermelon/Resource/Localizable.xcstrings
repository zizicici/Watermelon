          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le cache existant sera supprimé et toutes les photos seront ré-analysées. Cela peut prendre du temps."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "既存のキャッシュを削除し、すべての写真を再スキャンします。時間がかかる場合があります。"
