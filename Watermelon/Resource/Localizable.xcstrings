    "home.incompleteDownload.message" : {
      "localizations" : {
        "de" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld Objekt hat eine unvollständige Sicherung. Beim Herunterladen entsteht ein neues, separates Objekt, das bei einer erneuten Sicherung als neues Objekt gesichert werden kann."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld Objekte haben unvollständige Sicherungen. Beim Herunterladen entstehen neue, separate Objekte, die bei einer erneuten Sicherung als neue Objekte gesichert werden können."
                }
              }
            }
          }
        },
        "en" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld item has an incomplete backup. Downloading it creates a new, separate asset that may be backed up again as new."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld items have incomplete backups. Downloading them creates new, separate assets that may be backed up again as new."
                }
              }
            }
          }
        },
        "es" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld elemento tiene una copia de seguridad incompleta. Al descargarlo se crea un elemento nuevo e independiente que podría volver a incluirse como nuevo en otra copia de seguridad."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld elementos tienen copias de seguridad incompletas. Al descargarlos se crean elementos nuevos e independientes que podrían volver a incluirse como nuevos en otra copia de seguridad."
                }
              }
            }
          }
        },
        "es-419" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld elemento tiene un respaldo incompleto. Al descargarlo se crea un elemento nuevo e independiente que podría volver a respaldarse como nuevo."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld elementos tienen respaldos incompletos. Al descargarlos se crean elementos nuevos e independientes que podrían volver a respaldarse como nuevos."
                }
              }
            }
          }
        },
        "fr" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld élément a une sauvegarde incomplète. Le télécharger crée un nouvel élément distinct qui pourra être sauvegardé à nouveau en tant que nouvel élément."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld éléments ont des sauvegardes incomplètes. Les télécharger crée de nouveaux éléments distincts qui pourront être sauvegardés à nouveau en tant que nouveaux éléments."
                }
              }
            }
          }
        },
        "ja" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld 件の項目のバックアップが不完全です。ダウンロードすると、バックアップと一致しない新しい項目が作成され、今後のバックアップで新しい項目として再びバックアップされる場合があります。"
                }
              }
            }
          }
        },
        "ko" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld개 항목의 백업이 불완전합니다. 다운로드하면 백업과 일치하지 않는 새 항목이 생성되며 다시 백업하면 새 항목으로 백업될 수 있습니다."
                }
              }
            }
          }
        },
        "pt-BR" : {
          "variations" : {
            "plural" : {
