        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기존 캐시를 삭제하고 모든 사진을 다시 스캔합니다. 시간이 걸릴 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
