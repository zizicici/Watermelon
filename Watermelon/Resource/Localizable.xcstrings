    "backup.log.icloudAccessEnabled" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Zugriff auf iCloud-Fotos erlauben“ ist aktiviert. Watermelon kann iCloud-Originale bei Bedarf laden. Wenn nur in iCloud vorhandene lokale Ressourcen erkannt werden, wird die Parallelität dieses Laufs automatisch auf 1 gesetzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow iCloud Photo Access is enabled. Watermelon Backup may download iCloud originals on demand. If iCloud-only local resources are detected, this run will automatically switch concurrency to 1."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Permitir acceso a fotos de iCloud” está activado. Backup Sandía puede descargar originales de iCloud cuando sea necesario. Si se detectan recursos locales solo en iCloud, esta ejecución cambiará automáticamente la concurrencia a 1."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Permitir acceso a fotos de iCloud” está activado. Backup Sandía puede descargar originales de iCloud cuando sea necesario. Si se detectan recursos locales solo en iCloud, esta ejecución cambiará automáticamente la concurrencia a 1."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Autoriser l’accès aux photos iCloud » est activé. Watermelon peut télécharger les originaux iCloud à la demande. Si des ressources locales uniquement présentes sur iCloud sont détectées, cette exécution réduira automatiquement la simultanéité à 1."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「iCloud 写真へのアクセスを許可」が有効です。スイカバックアップは必要に応じて iCloud のオリジナルをダウンロードできます。iCloud のみに存在するローカルリソースが検出された場合、この実行の同時実行数は自動的に 1 に切り替わります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"iCloud 사진 접근 허용\"이 활성화되어 있습니다. 수박 백업은 필요할 때 iCloud 원본을 다운로드할 수 있습니다. iCloud에만 있는 로컬 리소스가 감지되면 이번 실행의 동시 실행 수가 자동으로 1로 전환됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Permitir acesso às fotos do iCloud” está ativado. O Backup Melancia pode baixar originais do iCloud sob demanda. Se forem detectados recursos locais apenas no iCloud, esta execução mudará automaticamente a concorrência para 1."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Permitir acesso às fotos do iCloud” está ativado. O Backup Melancia pode descarregar originais do iCloud sob demanda. Se forem detetados recursos locais apenas no iCloud, esta execução mudará automaticamente a concorrência para 1."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включён «Доступ к фото в iCloud». Арбуз Backup может загружать оригиналы из iCloud по запросу. Если будут обнаружены ресурсы только в iCloud, для этого запуска параллельность автоматически переключится на 1."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Увімкнено «Дозволити доступ до фото iCloud». Кавун Backup може завантажувати оригінали iCloud за потреби. Якщо буде виявлено локальні ресурси лише в iCloud, цей запуск автоматично зменшить паралельність до 1."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已启用「允许访问 iCloud 原件」：西瓜备份可按需下载 iCloud 原件。若检测到仅存于 iCloud 的本地资源，本次执行会自动将并发数改为 1。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已啟用「允許存取 iCloud 原件」：西瓜備份可按需下載 iCloud 原件。若偵測到僅存於 iCloud 的本機資源，本次執行會自動將並行數改為 1。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已啟用「允許存取 iCloud 原件」：西瓜備份可按需下載 iCloud 原件。若偵測到僅存於 iCloud 的本機資源，本次執行會自動將並行數改為 1。"
          }
        }
      }
    },
