    "onboarding.item.edited.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie ein Foto oder Video angepasst, zugeschnitten oder gekürzt haben, sichert Watermelon sowohl die Bearbeitung als auch das unbearbeitete Original und eine kleine Anpassungsdatei."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you've adjusted, cropped, or trimmed a photo or video, the backup includes both the edit and the unedited original, along with a small adjustment file."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si has ajustado, recortado o acortado una foto o un vídeo, la copia de seguridad incluye tanto la versión editada como el original sin editar, junto con un pequeño archivo de ajustes."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ajustaste, recortaste o acortaste una foto o un video, el respaldo incluye tanto la versión editada como el original sin editar, junto con un pequeño archivo de ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous avez ajusté, recadré ou raccourci une photo ou une vidéo, la sauvegarde inclut la version modifiée, l'original non modifié et un petit fichier d'ajustements."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真や動画を調整・切り抜き・トリミングした場合、編集後のファイルと未編集の元データ、調整内容を記録した小さなファイルがすべて含まれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진이나 동영상을 보정하거나 자르거나 길이를 조절한 경우 편집본, 편집하지 않은 원본, 작은 보정 파일이 함께 백업됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você ajustou, cortou ou aparou uma foto ou vídeo, o backup inclui a edição, o original sem edição e um pequeno arquivo de ajustes."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ajustou, cortou ou aparou uma foto ou vídeo, o backup inclui a edição, o original sem edição e um pequeno ficheiro de ajustes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы корректировали, кадрировали или подрезали фото или видео, в резервную копию попадут и редактированная версия, и неотредактированный оригинал, а также небольшой файл с настройками."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо ви налаштовували, обрізали або скорочували фото чи відео, у бекапі будуть і відредагована версія, і незмінений оригінал, а також невеликий файл із налаштуваннями."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若照片或视频经过调整、裁剪或剪辑，备份会同时包含编辑后版本、未编辑的原始文件，以及一个记录调整的小文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若照片或影片經過調整、裁剪或剪輯，備份會同時包含編輯後版本、未編輯的原始檔案，以及一個記錄調整的小檔案。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若相片或影片經過調整、裁剪或剪輯，備份會同時包含編輯後版本、未編輯的原始檔案，以及一個記錄調整的小檔案。"
          }
        }
      }
    },
