        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de découvrir les services SMB locaux. Veuillez vérifier les permissions du réseau local ou réessayer plus tard."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカル SMB サービスを検出できません。ローカルネットワークの権限を確認するか、しばらくしてからもう一度お試しください。"
