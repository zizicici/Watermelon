            "value" : "O cache existente será apagado e todas as fotos serão verificadas novamente. Pode demorar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A cache existente será apagada e todas as fotografias serão analisadas novamente. Pode demorar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Существующий кеш будет удалён, все фото отсканируются заново. Это может занять время."
