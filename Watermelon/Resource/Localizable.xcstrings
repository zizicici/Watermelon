    "log.focusMode.alertMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Bildschirm wird vollständig schwarz und während der Aufgabe nicht automatisch gesperrt. Tippen Sie auf den Bildschirm, um den Modus zu beenden. Nach Abschluss der Aufgabe wird die automatische Sperre wieder aktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The screen turns pure black and won't auto-lock while the task runs. Tap the screen to exit. Auto-lock is restored once the task ends."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pantalla se vuelve completamente negra y no se bloquea automáticamente mientras la tarea está en curso. Toca la pantalla para salir. El bloqueo automático se restaurará al terminar la tarea."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pantalla se vuelve completamente negra y no se bloquea automáticamente mientras la tarea está en curso. Toca la pantalla para salir. El bloqueo automático se restaurará al terminar la tarea."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'écran devient entièrement noir et ne se verrouille pas automatiquement pendant l'exécution de la tâche. Touchez l'écran pour quitter. Le verrouillage automatique est rétabli à la fin de la tâche."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面が真っ黒になり、タスク実行中は自動ロックされません。画面をタップすると終了します。タスク終了後、自動ロックは元に戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "화면이 완전히 검게 변하고 작업 실행 중에는 자동 잠금이 되지 않습니다. 화면을 탭하면 종료됩니다. 작업이 끝나면 자동 잠금이 복원됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A tela fica completamente preta e não bloqueia automaticamente enquanto a tarefa está em execução. Toque na tela para sair. O bloqueio automático será restaurado quando a tarefa terminar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O ecrã fica completamente preto e não bloqueia automaticamente enquanto a tarefa está em execução. Toque no ecrã para sair. O bloqueio automático será restaurado quando a tarefa terminar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Экран станет полностью чёрным и не будет блокироваться, пока выполняется задача. Коснитесь экрана, чтобы выйти. Автоблокировка восстановится после завершения задачи."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Екран стане повністю чорним і не блокуватиметься автоматично під час виконання завдання. Торкніться екрана, щоб вийти. Автоблокування відновиться після завершення завдання."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "屏幕将变为纯黑，任务期间不会自动锁定。轻点屏幕可退出；任务结束后会恢复自动锁定设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "螢幕將變為純黑，任務期間不會自動鎖定。點一下螢幕可退出；任務結束後會恢復自動鎖定設定。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "螢幕將變為純黑，任務期間不會自動鎖定。點按螢幕可退出；任務結束後會恢復自動鎖定設定。"
          }
        }
      }
    },
