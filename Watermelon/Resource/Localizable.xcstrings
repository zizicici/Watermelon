          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Índice local incompleto: %@. Para evitar fotos duplicadas durante la descarga o complemento, esta operación se ha detenido. Active \"Permitir acceso a fotos de iCloud\" en los ajustes o descargue primero estos originales a su dispositivo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Índice local incompleto: %@. Para evitar fotos duplicadas durante la descarga o complemento, esta operación se ha detenido. Activa \"Permitir acceso a fotos de iCloud\" en los ajustes o descarga primero estos originales a tu dispositivo."
          }
        },
