    "auth.s3.secretKey.footerEdit" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der gespeicherte Secret Access Key wird als ******** angezeigt. Lassen Sie ihn unverändert, um ihn beizubehalten, oder geben Sie einen neuen Wert ein. Leeren Sie das Feld, um einen leeren Secret Access Key zu speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The saved Secret Access Key is shown as ********. Leave it unchanged to keep it; type to replace it. Clear the field to save an empty Secret Access Key."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Secret Access Key guardada se muestra como ********. No la edites para conservarla; escribe para reemplazarla. Borra el campo para guardar una Secret Access Key vacía."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Secret Access Key guardada se muestra como ********. No la edites para conservarla; escribe para reemplazarla. Borra el campo para guardar una Secret Access Key vacía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Secret Access Key enregistrée s’affiche sous la forme ********. Ne la modifiez pas pour la conserver ; saisissez une valeur pour la remplacer. Effacez le champ pour enregistrer une Secret Access Key vide."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存済みの Secret Access Key は ******** と表示されます。変更しなければそのまま使用されます。入力すると置き換わります。空にすると空の Secret Access Key として保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장된 Secret Access Key는 ********로 표시됩니다. 그대로 두면 유지되고, 입력하면 교체됩니다. 필드를 비우면 빈 Secret Access Key로 저장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Secret Access Key salva aparece como ********. Não edite para mantê-la; digite para substituí-la. Limpe o campo para salvar uma Secret Access Key vazia."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Secret Access Key guardada aparece como ********. Não edite para a manter; introduza texto para a substituir. Limpe o campo para guardar uma Secret Access Key vazia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохранённая Secret Access Key отображается как ********. Не изменяйте её, чтобы сохранить; введите новое значение, чтобы заменить. Очистите поле, чтобы сохранить пустую Secret Access Key."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Збережена Secret Access Key відображається як ********. Не змінюйте її, щоб зберегти; введіть нове значення, щоб замінити. Очистьте поле, щоб зберегти порожню Secret Access Key."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已保存的 Secret Access Key 会显示为 ********。不修改会继续使用；输入内容会替换它。清空字段会保存为空 Secret Access Key。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已儲存的 Secret Access Key 會顯示為 ********。不修改會繼續使用；輸入內容會取代它。清空欄位會儲存為空 Secret Access Key。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已儲存的 Secret Access Key 會顯示為 ********。不修改會繼續使用；輸入內容會取代它。清空欄位會儲存為空 Secret Access Key。"
          }
        }
      }
    },
