    "home.alert.remoteSelectionUnavailableMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Herunterladen und Ergänzen sind nicht verfügbar, wenn die lokale Quelle auf bestimmte Alben festgelegt ist. Wechseln Sie zu „Alle Fotos“, um Remote-Monate auszuwählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Download and complement are unavailable when the local source is specific albums. Switch to All Photos to select remote months."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las opciones Descargar y Completar no están disponibles cuando la fuente local contiene álbumes específicos. Cambia a Todas las fotos para seleccionar meses remotos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las opciones Descargar y Completar no están disponibles cuando la fuente local contiene álbumes específicos. Cambia a Todas las fotos para seleccionar meses remotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le téléchargement et le complément ne sont pas disponibles lorsque la source locale est définie sur des albums spécifiques. Passez à Toutes les photos pour sélectionner des mois distants."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカルソースが特定のアルバムの場合、ダウンロードと補完は利用できません。リモートの月を選択するには「すべての写真」に切り替えてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로컬 소스가 특정 앨범이면 다운로드와 보완을 사용할 수 없습니다. 원격 월을 선택하려면 모든 사진으로 전환하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Download e complemento não estão disponíveis quando a fonte local é Álbuns específicos. Mude para Todas as Fotos para selecionar meses remotos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A transferência e o complemento não estão disponíveis quando a origem local são álbuns específicos. Mude para Todas as Fotografias para selecionar meses remotos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузка и дополнение недоступны, когда локальный источник — отдельные альбомы. Переключитесь на «Все фото», чтобы выбирать удалённые месяцы."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Завантаження й доповнення недоступні, коли локальним джерелом є певні альбоми. Перемкніться на Усі фото, щоб вибрати віддалені місяці."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本地来源为特定相册时，不能下载或互补。切换到全部照片后才可选择远端月份。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本機來源為特定相簿時，不能下載或互補。切換到全部照片後才可選擇遠端月份。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本機來源為特定相簿時，無法下載或互補。切換至全部相片後才可選擇遠端月份。"
          }
        }
      }
