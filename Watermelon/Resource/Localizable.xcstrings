    "auth.sftp.hostKey.confirmBody" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist die erste Verbindung. Prüfen Sie, ob dieser Fingerabdruck mit dem bekannten Fingerabdruck des Servers übereinstimmt:\n\n%@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the first connection. Verify that this fingerprint matches the server’s known fingerprint:\n\n%@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primera conexión. Verifica que coincide con la huella conocida del servidor:\n\n%@"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primera conexión. Verifica que coincida con la huella conocida del servidor:\n\n%@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Première connexion. Vérifiez que cela correspond à l'empreinte connue du serveur :\n\n%@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "初回接続です。サーバーの既知のフィンガープリントと一致するか確認してください：\n\n%@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "첫 연결입니다. 서버의 알려진 지문과 일치하는지 확인하세요:\n\n%@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primeira conexão. Verifique se corresponde à impressão digital conhecida do servidor:\n\n%@"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
