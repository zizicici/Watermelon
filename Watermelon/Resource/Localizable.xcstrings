    "onboarding.item.live_photo.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon sichert jedes Live Photo als Standbild und zugehöriges Video. Beim erneuten Import über Watermelon werden sie automatisch wieder zu einem Live Photo zusammengeführt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon Backup backs up each Live Photo as a still image and a paired video. When you re-import using Watermelon Backup, they're automatically merged back into a Live Photo."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía guarda cada Live Photo como una imagen fija y su vídeo. Al volver a importarlas con Backup Sandía, se combinan de nuevo en una Live Photo automáticamente."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup Sandía guarda cada Live Photo como una imagen fija y su video. Al volver a importarlas con Backup Sandía, se combinan de nuevo en una Live Photo automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Watermelon sauvegarde chaque Live Photo sous forme d'image fixe et de vidéo associée. Lors d'un réimport via Watermelon, elles sont automatiquement recombinées en Live Photo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スイカバックアップは Live Photos を静止画と動画のペアとして保存します。スイカバックアップで読み込み直すと自動的に Live Photo に戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "수박 백업은 Live Photo를 정지 이미지와 동영상 한 쌍으로 백업합니다. 수박 백업으로 다시 가져오면 자동으로 Live Photo로 병합됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia faz backup de cada Live Photo como uma imagem estática e um vídeo emparelhado. Ao reimportar pelo Backup Melancia, eles voltam a ser combinados em uma Live Photo automaticamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Backup Melancia faz backup de cada Live Photo como uma imagem estática e um vídeo emparelhado. Ao reimportar através do Backup Melancia, voltam a ser combinados numa Live Photo automaticamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Арбуз Backup сохраняет каждое Live Photo как отдельное изображение и связанное видео. При повторном импорте через Арбуз Backup они автоматически объединяются обратно в Live Photo."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кавун Backup зберігає кожне Live Photo як нерухоме зображення й пов'язане відео. Під час повторного імпорту через Кавун Backup вони автоматично об'єднуються назад у Live Photo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "备份会把每张 Live 图分别保存为静态图和配套视频。再次用西瓜备份导入时，会自动合并回 Live 图。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "備份會把每張 Live 圖分別儲存為靜態圖與配套影片。再次用西瓜備份匯入時，會自動合併回 Live 圖。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "備份會將每張 Live 圖分別儲存為靜態相片同配套影片，再次用西瓜備份匯入時會自動合併返做 Live 圖。"
          }
        }
      }
    },
