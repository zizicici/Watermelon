    "storage.detail.deleteConfirm.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung wird entfernt und gespeicherte Anmeldedaten werden aus dem Schlüsselbund gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The connection will be removed and any saved credentials will be deleted from the keychain. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminará la conexión y las credenciales guardadas se borrarán del llavero. Esta acción no se puede deshacer."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminará la conexión y las credenciales guardadas se borrarán del llavero. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion sera supprimée et les identifiants enregistrés seront supprimés du trousseau. Cette action est irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "接続が削除され、キーチェーンに保存された資格情報も削除されます。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연결이 제거되고 저장된 자격 증명이 키체인에서 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A conexão será removida e as credenciais salvas serão excluídas do chaveiro. Esta ação não pode ser desfeita."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A ligação será removida e as credenciais guardadas serão eliminadas do porta-chaves. Esta ação não pode ser anulada."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "З’єднання буде видалено, а збережені облікові дані — стерті зі сховища ключів. Цю дію не можна скасувати."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将移除该连接，并从钥匙串中删除已保存的凭据。此操作不可撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將移除該連線，並從鑰匙圈中刪除已儲存的憑證。此操作無法復原。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將移除該連線，並從鑰匙圈中刪除已儲存的憑證。此操作無法復原。"
          }
        }
      }
    },
