        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A chave do host mudou inesperadamente. O servidor pode ter sido substituído ou a conexão está sendo interceptada. Nova impressão digital: %@"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
