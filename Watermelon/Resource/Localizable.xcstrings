    "settings.background.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, sichert %@ im Hintergrund automatisch Fotos und Videos der letzten zwei Monate, wenn das Gerät geladen wird und mit WLAN verbunden ist.\nÄltere Monate müssen manuell in der App gesichert werden.\nUnterstützt SMB und WebDAV (kein externer Speicher)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, %@ will automatically back up photos and videos from the last two months in the background when the device is charging and connected to Wi-Fi.\nOlder months must be backed up manually in the app.\nSupports SMB and WebDAV (external storage not supported)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está activado, %@ respaldará automáticamente fotos y vídeos de los últimos dos meses en segundo plano cuando el dispositivo esté cargando y conectado a Wi-Fi.\nLos meses más antiguos deben respaldarse manualmente.\nCompatible con SMB y WebDAV (no almacenamiento externo)."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está activado, %@ respaldará automáticamente fotos y videos de los últimos dos meses en segundo plano cuando el dispositivo esté cargando y conectado a Wi-Fi.\nLos meses más antiguos deben respaldarse manualmente.\nCompatible con SMB y WebDAV (sin almacenamiento externo)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque activé, %@ sauvegardera automatiquement les photos et vidéos des deux derniers mois en arrière-plan lorsque l'appareil est en charge et connecté au Wi-Fi.\nLes mois plus anciens doivent être sauvegardés manuellement.\nPrise en charge de SMB et WebDAV (pas de stockage externe)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、デバイスが充電中かつ Wi-Fi に接続されているときに、%@ がバックグラウンドで直近 2 か月分の写真と動画を自動バックアップします。\nそれ以前の月はアプリ内で手動バックアップしてください。\nSMB と WebDAV に対応（外部ストレージ非対応）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 기기가 충전 중이고 Wi-Fi에 연결되어 있을 때 %@이(가) 백그라운드에서 최근 2개월의 사진과 동영상을 자동으로 백업합니다.\n이전 월은 앱에서 수동으로 백업하세요.\nSMB 및 WebDAV 지원 (외장 저장소 미지원)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando ativado, o %@ fará backup automático de fotos e vídeos dos últimos dois meses em segundo plano quando o dispositivo estiver carregando e conectado ao Wi-Fi.\nMeses mais antigos devem ser copiados manualmente.\nCompatível com SMB e WebDAV (sem armazenamento externo)."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando ativado, o %@ fará cópia automática de fotos e vídeos dos últimos dois meses em segundo plano quando o dispositivo estiver a carregar e ligado ao Wi-Fi.\nMeses mais antigos devem ser copiados manualmente.\nCompatível com SMB e WebDAV (sem armazenamento externo)."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли увімкнено, %@ автоматично створюватиме резервні копії фотографій та відео за останні два місяці у фоновому режимі, коли пристрій заряджається та підключений до Wi-Fi.\nСтаріші місяці потрібно копіювати вручну.\nПідтримує SMB та WebDAV (зовнішнє сховище не підтримується)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，设备连接电源并使用 Wi-Fi 时，%@ 会在后台自动备份最近两个月的照片和视频。\n更早的月份请在应用内手动备份。\n支持 SMB 和 WebDAV（不支持外接存储）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，裝置連接電源並使用 Wi-Fi 時，%@ 會在背景自動備份最近兩個月的照片和影片。\n更早的月份請在 App 內手動備份。\n支援 SMB 和 WebDAV（不支援外接儲存）。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，裝置連接電源並使用 Wi-Fi 時，%@ 會在背景自動備份最近兩個月的相片和影片。\n更早的月份請在 App 內手動備份。\n支援 SMB 和 WebDAV（不支援外接儲存）。"
          }
        }
      }
    },
