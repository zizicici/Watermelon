    "home.localIndex.rebuildDetail" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Cache wird geleert und alle Einträge werden neu erstellt. Dies dauert länger, kann aber einen beschädigten Index wiederherstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear the cache and rebuild every entry. This is slower but can recover from corrupted data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vacía la caché y reconstruye cada entrada. Lento, pero recupera datos corruptos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vacía la caché y reconstruye cada entrada. Lento, pero recupera datos corruptos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vide le cache et reconstruit chaque entrée. Lent mais corrige les données corrompues."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャッシュを消去し、すべてのエントリを再作成します。時間はかかりますが、破損したキャッシュから復旧できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캐시를 비우고 모든 항목을 다시 만듭니다. 느리지만 손상된 데이터를 복구합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpa o cache e reconstrói todas as entradas. Lento, mas recupera dados corrompidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpa a cache e reconstrói todas as entradas. Lento, mas recupera dados corrompidos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очистить кеш и перестроить все записи. Медленно, но восстанавливает данные после повреждения."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очищає кеш і перебудовує кожен запис. Повільно, але виправляє пошкоджені дані."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清空缓存并重建每一条记录，速度较慢，但可恢复损坏的数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除快取並重建每一筆記錄。速度較慢，但可復原損毀的資料。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除快取並重建每一筆記錄。速度較慢，但可復原損毀的資料。"
          }
        }
      }
    },
