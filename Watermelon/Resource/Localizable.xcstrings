    "settings.monthGroupingTimeZone.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt fest, welchem Monat lokale Fotos auf diesem Gerät zugeordnet werden. Änderungen wirken sich auf die lokale Gruppierung, Auswahlbereiche und die Gruppierung zukünftiger Backups auf diesem Gerät aus. Vorhandene Monatsdateien im Remote-Speicher werden nicht verschoben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decides which month local photos belong to on this device. Changing it affects local grouping, selection scopes, and future backup grouping on this device; existing remote month files are not moved."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decide a qué mes pertenecen las fotos locales en este dispositivo. Al cambiarlo se modifican la agrupación local, los rangos de selección y la agrupación de futuras copias de seguridad en este dispositivo; los archivos mensuales remotos existentes no se mueven."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Determina a qué mes pertenecen las fotos locales en este dispositivo. Al cambiarla, se modifican la agrupación local, los alcances de selección y la agrupación de respaldos futuros en este dispositivo; los archivos de meses remotos existentes no se mueven."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Détermine à quel mois appartiennent les photos locales sur cet appareil. Le modifier affecte le regroupement local, les plages de sélection et le regroupement des futures sauvegardes sur cet appareil; les fichiers mensuels distants existants ne sont pas déplacés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデバイス上の写真をどの月に分類するかを決めます。変更すると、ローカルでの月別表示、選択範囲、このデバイスで今後作成するバックアップの月分けに影響します。リモートにある既存の月別ファイルは移動されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기에서 로컬 사진이 어느 달에 속하는지 결정합니다. 변경하면 이 기기의 로컬 그룹화, 선택 범위, 이후 백업 그룹화에 영향을 줍니다. 기존 원격 월별 파일은 이동되지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decide a qual mês as fotos locais pertencem neste dispositivo. Alterar isso afeta o agrupamento local, os escopos de seleção e o agrupamento de backups futuros neste dispositivo; os arquivos mensais remotos existentes não são movidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decide a que mês pertencem as fotografias locais neste dispositivo. Alterar isto afeta o agrupamento local, os âmbitos de seleção e o agrupamento de cópias de segurança futuras neste dispositivo; os ficheiros mensais remotos existentes não são movidos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Определяет, к какому месяцу относятся локальные фото на этом устройстве. Изменение влияет на локальную группировку, области выбора и группировку будущих резервных копий на этом устройстве; существующие удалённые месячные файлы не перемещаются."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Визначає, до якого місяця належать локальні фото на цьому пристрої. Зміна впливає на локальне групування, області вибору й групування майбутніх резервних копій на цьому пристрої; наявні віддалені місячні файли не переміщуються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "决定本机照片属于哪个月份。更改会影响此设备上的本地分组、选择范围和之后的备份分组；已有远端月份文件不会移动。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決定本機照片屬於哪個月份。更改會影響此裝置上的本機分組、選擇範圍和之後的備份分組；已有遠端月份檔案不會移動。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "決定本機相片屬於哪個月份。更改會影響此裝置上的本機分組、選擇範圍和之後的備份分組；已有遠端月份檔案不會移動。"
          }
        }
      }
    },
