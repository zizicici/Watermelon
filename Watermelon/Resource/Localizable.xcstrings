          "stringUnit" : {
            "state" : "translated",
            "value" : "한도에 도달하면 가장 오랫동안 사용하지 않은 썸네일이 자동으로 삭제됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o limite é atingido, as miniaturas usadas menos recentemente são removidas automaticamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o limite é atingido, as miniaturas usadas menos recentemente são removidas automaticamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При достижении лимита реже всего используемые миниатюры удаляются автоматически."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли ліміт досягнуто, мініатюри, які найдовше не використовувалися, видаляються автоматично."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "达到上限后，最久未使用的缩略图会被自动清除。"
          }
