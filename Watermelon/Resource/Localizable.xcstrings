    "auth.sftp.hostKey.changedBody" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Hostschlüssel des Servers hat sich seit dem Speichern dieses Profils geändert. Der Server wurde möglicherweise neu installiert oder die Verbindung wird abgefangen.\n\nErwartet: %1$@\nEmpfangen: %2$@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The server's host key has changed since this profile was saved. The server may have been reinstalled, or the connection is being intercepted.\n\nExpected: %1$@\nReceived: %2$@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clave del host del servidor ha cambiado desde que se guardó este perfil. Puede que el servidor se haya reinstalado o que la conexión esté siendo interceptada.\n\nEsperada: %1$@\nRecibida: %2$@"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clave del host del servidor cambió desde que se guardó este perfil. Puede que el servidor se haya reinstalado o que la conexión esté siendo interceptada.\n\nEsperada: %1$@\nRecibida: %2$@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La clé hôte du serveur a changé depuis l'enregistrement de ce profil. Le serveur a peut-être été réinstallé, ou la connexion est interceptée.\n\nAttendue : %1$@\nReçue : %2$@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このプロファイルを保存して以降、サーバーのホスト鍵が変更されました。サーバーが再インストールされたか、接続が傍受されている可能性があります。\n\n想定されるフィンガープリント：%1$@\n受信したフィンガープリント：%2$@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 프로필을 저장한 이후 서버의 호스트 키가 변경되었습니다. 서버가 다시 설치되었거나 연결이 가로채인 상태일 수 있습니다.\n\n예상 지문: %1$@\n수신한 지문: %2$@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A chave do host do servidor mudou desde que este perfil foi salvo. O servidor pode ter sido reinstalado ou a conexão está sendo interceptada.\n\nEsperada: %1$@\nRecebida: %2$@"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A chave do host do servidor mudou desde que este perfil foi guardado. O servidor pode ter sido reinstalado ou a ligação está a ser intercetada.\n\nEsperada: %1$@\nRecebida: %2$@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ключ хоста сервера изменился с момента сохранения профиля. Возможно, сервер был переустановлен или подключение перехватывается.\n\nОжидался: %1$@\nПолучен: %2$@"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ключ хоста сервера змінився після збереження цього профілю. Можливо, сервер було перевстановлено, або з'єднання перехоплюється.\n\nОчікуваний: %1$@\nОтриманий: %2$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存此配置后，服务器主机密钥已变更。服务器可能被重新安装，或连接正在被中间人拦截。\n\n预期指纹：%1$@\n收到的指纹：%2$@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "儲存此設定後，伺服器主機金鑰已變更。伺服器可能已重新安裝，或連線遭中間人攔截。\n\n預期指紋：%1$@\n收到的指紋：%2$@"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "儲存此設定後，伺服器主機金鑰已變更。伺服器可能已重新安裝，或連線遭中間人攔截。\n\n預期指紋：%1$@\n收到的指紋：%2$@"
          }
        }
      }
    },
