    "remoteThumbnails.maintenance.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Schalter betrifft nur zukünftige Backups. Erzeugen Sie Miniaturbilder für vorhandene Backups oder löschen Sie sie, um Speicherplatz auf dem Knoten freizugeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The switch only affects future backups. Generate thumbnails for existing backups, or delete them to reclaim space on the node."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El interruptor solo afecta a las copias de seguridad futuras. Genera miniaturas para el contenido que ya está en la copia de seguridad o elimínalas para liberar espacio en el nodo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El interruptor solo afecta a los respaldos futuros. Genera miniaturas para el contenido que ya está respaldado o elimínalas para liberar espacio en el nodo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le réglage n'affecte que les sauvegardes futures. Générez des miniatures pour le contenu déjà sauvegardé ou supprimez-les pour libérer de l'espace sur le nœud."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このスイッチは今後のバックアップにのみ影響します。バックアップ済みのコンテンツ用にサムネールを生成することも、サムネールを削除してノードの空き容量を増やすこともできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 설정은 향후 백업에만 영향을 줍니다. 이미 백업된 콘텐츠를 위한 썸네일을 생성하거나 삭제하여 노드 공간을 확보하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A opção só afeta backups futuros. Gere miniaturas para o conteúdo já salvo ou exclua-as para liberar espaço no nó."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A opção só afeta cópias de segurança futuras. Gere miniaturas para o conteúdo já guardado ou elimine-as para libertar espaço no nó."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переключатель влияет только на будущие резервные копии. Создайте миниатюры для уже сохранённого содержимого или удалите их, чтобы освободить место на узле."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перемикач впливає лише на майбутні резервні копії. Створіть мініатюри для вже збереженого вмісту або видаліть їх, щоб звільнити місце на вузлі."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开关只影响以后的备份。可为已备份内容生成缩略图，或删除以回收节点空间。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開關只影響以後的備份。可為已備份內容產生縮圖，或刪除以回收節點空間。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開關只影響以後的備份。可為已備份內容產生縮圖，或刪除以回收節點空間。"
          }
        }
      }
