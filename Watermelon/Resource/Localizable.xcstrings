    "remoteThumbnails.backfill.promptMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Schalter gilt nur für zukünftige Backups. Miniaturbilder für bereits auf diesem Knoten gesicherte Inhalte erzeugen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The switch only applies to future backups. Generate thumbnails for content already backed up to this node?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El interruptor solo se aplica a las copias de seguridad futuras. ¿Quieres generar miniaturas del contenido que ya está en la copia de seguridad de este nodo?"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El interruptor solo se aplica a los respaldos futuros. ¿Quieres generar miniaturas del contenido que ya está respaldado en este nodo?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le réglage ne s'applique qu'aux sauvegardes futures. Générer des miniatures pour le contenu déjà sauvegardé sur ce nœud ?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このスイッチは今後のバックアップにのみ適用されます。このノードにすでにバックアップ済みのコンテンツのサムネールを生成しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 설정은 향후 백업에만 적용됩니다. 이 노드에 이미 백업된 콘텐츠의 썸네일을 생성할까요?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A opção só se aplica a backups futuros. Gerar miniaturas para o conteúdo já salvo neste nó?"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A opção só se aplica a cópias de segurança futuras. Gerar miniaturas para o conteúdo já guardado neste nó?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переключатель применяется только к будущим резервным копиям. Создать миниатюры для содержимого, уже сохранённого на этом узле?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перемикач застосовується лише до майбутніх резервних копій. Створити мініатюри для вмісту, уже збереженого на цьому вузлі?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开关只对以后的备份生效。要为已备份到此节点的内容生成缩略图吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開關只對以後的備份生效。要為已備份到此節點的內容產生縮圖嗎？"
          }
        },
        "zh-HK" : {
