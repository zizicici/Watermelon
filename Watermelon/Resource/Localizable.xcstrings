        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Download e complemento não estão disponíveis quando a fonte local é Álbuns específicos. Mude para Todas as Fotos para selecionar meses remotos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
