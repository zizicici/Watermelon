    "migration.options.skipPerceptual.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die App berechnet einen perzeptuellen Hash für HEIC-/JPG-Fotos aus den Altdaten. Wenn das Ziel dasselbe Bild bereits in einem beliebigen Format enthält, wird die Altdatenkopie übersprungen. Beim ersten Scan werden die Zielfotos heruntergeladen und indiziert; spätere Scans verwenden den lokalen Cache."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app computes a perceptual hash for legacy HEIC/JPG photos. If the target already contains the same picture in any format, the legacy copy is skipped. The first scan downloads target photos to index them; subsequent scans use the local cache."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula un hash perceptual de las fotos HEIC/JPG antiguas. Si el destino ya contiene la misma imagen en cualquier formato, se omite la copia antigua. El primer análisis descarga las fotos de destino para indexarlas; los siguientes usan la caché local."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula un hash perceptual de las fotos HEIC/JPG antiguas. Si el destino ya contiene la misma imagen en cualquier formato, se omite la copia antigua. El primer análisis descarga las fotos de destino para indexarlas; los siguientes usan la caché local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcule un hachage perceptuel pour les anciennes photos HEIC/JPG. Si la cible contient déjà la même image, quel que soit son format, l’ancienne copie est ignorée. La première analyse télécharge les photos de la cible pour les indexer ; les suivantes utilisent le cache local."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レガシー側の HEIC/JPG 写真から知覚ハッシュを計算します。ターゲット側に同じ写真が別の形式ですでに存在する場合、レガシー側のコピーをスキップします。初回のスキャンではターゲット側の写真をダウンロードしてインデックスを作成し、以降はローカルキャッシュを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이전 HEIC/JPG 사진의 유사 이미지 해시를 계산합니다. 대상에 같은 사진이 어떤 형식으로든 이미 있으면 이전 사본을 건너뜁니다. 첫 검사에서는 대상 사진을 다운로드해 인덱싱하고, 이후 검사에서는 로컬 캐시를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula um hash perceptual para as fotos antigas em HEIC/JPG. Se o destino já contiver a mesma foto em qualquer formato, a cópia antiga será ignorada. A primeira análise baixa as fotos do destino para indexá-las; as análises seguintes usam o cache local."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula um hash percetual para as fotografias antigas em HEIC/JPG. Se o destino já contiver a mesma fotografia em qualquer formato, a cópia antiga será ignorada. A primeira análise descarrega as fotografias do destino para as indexar; as análises seguintes usam a cache local."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение вычисляет перцептивный хеш для фото прежней версии в форматах HEIC/JPG. Если в целевом хранилище уже есть то же изображение в любом формате, копия из прежней версии пропускается. Первое сканирование загружает фото из целевого хранилища для индексации; последующие используют локальный кэш."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Застосунок обчислює перцептивний хеш фотографій HEIC/JPG із даних попередньої версії. Якщо цільове сховище вже містить те саме зображення в будь-якому форматі, копію з даних попередньої версії буде пропущено. Під час першого сканування фото із цільового сховища завантажуються для індексування; наступні сканування використовують локальний кеш."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为旧版数据中的 HEIC/JPG 照片计算感知哈希。如果目标中已有任意格式的同一张照片，则跳过旧版副本。首次扫描会下载目标照片以建立索引；后续扫描会使用本地缓存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為舊版資料中的 HEIC/JPG 照片計算感知雜湊。如果目標中已有任意格式的同一張照片，則略過舊版副本。首次掃描會下載目標照片以建立索引；後續掃描會使用本機快取。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為舊版資料中的 HEIC/JPG 相片計算感知雜湊。如果目標中已有任意格式的同一張相片，則略過舊版副本。首次掃描會下載目標相片以建立索引；後續掃描會使用本機快取。"
          }
        }
      }
    },
