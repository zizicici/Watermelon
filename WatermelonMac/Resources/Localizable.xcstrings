    "migration.options.replaceSubsets.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die Dateien eines vorhandenen Medienobjekts im Ziel eine Teilmenge der Quelldateien sind, wird das unvollständige Medienobjekt im Ziel gelöscht und durch die vollständigere Version aus der Quelle ersetzt. Wenn die Option deaktiviert ist, bleiben beide erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the target already has an Asset whose files are a subset of the source, delete it and use the source's more complete version. When off, keep both."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si el destino ya contiene un elemento cuyos archivos son un subconjunto de los del origen, se elimina y se usa la versión más completa del origen. Desactivado: se conservan ambos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si el destino ya contiene un elemento cuyos archivos son un subconjunto de los del origen, se elimina y se usa la versión más completa del origen. Desactivado: se conservan ambos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la cible contient déjà un élément dont les fichiers forment un sous-ensemble de ceux de la source, il est supprimé au profit de la version plus complète de la source. Lorsque cette option est désactivée, les deux sont conservés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インポート元が、ターゲット側にある既存アセットのすべてのファイルに加えて、adjustment や alternate などの追加ロールを含む場合、ターゲット側の不完全なアセットを削除し、インポート元の完全なバージョンに置き換えます。オフの場合は両方を保持します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "대상에 파일 구성이 원본의 일부인 항목이 이미 있으면 해당 항목을 삭제하고 원본의 더 완전한 버전을 사용합니다. 끄면 둘 다 유지합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando a fonte contém todos os arquivos de um Asset existente no destino mais funções adicionais (ajustes, alternativos), o Asset incompleto é excluído e substituído pela versão completa da fonte. Desativado: ambos são mantidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando a origem contém todos os ficheiros de um Asset existente no destino mais funções adicionais (ajustes, alternativos), o Asset incompleto é eliminado e substituído pela versão completa da origem. Desativado: ambos são mantidos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если в целевом хранилище уже есть объект, файлы которого являются подмножеством исходного, он будет удалён и заменён более полной исходной версией. Если параметр выключен, сохранятся оба объекта."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо в цільовому сховищі вже є об’єкт, файли якого становлять підмножину файлів у джерелі, видалити його й використати повнішу версію з джерела. Якщо вимкнено, зберегти обидва."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果目标中已有项目的文件只是来源项目文件的子集，则删除目标中的不完整项目，改用来源中更完整的版本。关闭时保留两者。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果目標中已有項目的檔案只是來源項目檔案的子集，則刪除目標中的不完整項目，改用來源中更完整的版本。關閉時保留兩者。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果目標中已有項目的檔案只是來源項目檔案的子集，則刪除目標中的不完整項目，改用來源中更完整的版本。關閉時保留兩者。"
          }
        }
      }
    },
