    "menu.clearPerceptualCache.confirm.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld Einträge (%@) werden gelöscht. Spätere Scans müssen die Hashes für Legacy- und Zielfotos neu berechnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld entries (%@) will be deleted. Future scans will need to recompute hashes for legacy and target photos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminarán %lld entradas (%@). Los próximos escaneos deberán recalcular los hashes de las fotos legacy y de destino."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminarán %lld entradas (%@). Los próximos escaneos deberán recalcular los hashes de las fotos legacy y de destino."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld entrées (%@) seront supprimées. Les prochains scans devront recalculer les hashs des photos legacy et cible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 件 (%@) を削除します。次回のスキャンでは、レガシーとターゲットの写真のハッシュを再計算する必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld개 항목(%@)이 삭제됩니다. 이후 스캔에서는 레거시와 대상 사진의 해시를 다시 계산해야 합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld entradas (%@) serão excluídas. Varreduras futuras precisarão recalcular os hashes das fotos legacy e do destino."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld entradas (%@) serão eliminadas. Análises futuras terão de recalcular os hashes das fotos legacy e de destino."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буде видалено %lld записів (%@). Наступні сканування доведеться перерахувати хеші для legacy та цільових фото."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将删除 %lld 条记录 (%@)。下次 scan 需要对 legacy 和 target 照片重新计算哈希。"
