    "migration.options.replaceSubsets.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die Quelle alle Dateien eines vorhandenen Ziel-Assets enthält und zusätzliche Rollen (Anpassungen, Alternativen) hat, wird das unvollständige Ziel-Asset gelöscht und durch die vollständige Version aus der Quelle ersetzt. Aus: beide bleiben erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the target already has an Asset whose files are a subset of the source, delete it and use the source's more complete version. Off: keep both."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando la fuente contiene todos los archivos de un Asset existente del destino más roles adicionales (ajustes, alternativas), el Asset incompleto se elimina y se reemplaza por la versión completa de la fuente. Desactivado: se mantienen ambos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando la fuente contiene todos los archivos de un Asset existente del destino más roles adicionales (ajustes, alternativas), el Asset incompleto se elimina y se reemplaza por la versión completa de la fuente. Desactivado: se mantienen ambos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque la source contient tous les fichiers d'un Asset existant de la cible plus des rôles supplémentaires (ajustements, alternatives), l'Asset incomplet est supprimé et remplacé par la version complète de la source. Désactivé : les deux sont conservés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "インポート元が、ターゲット側にある既存アセットのすべてのファイルに加えて、adjustment や alternate などの追加ロールを含む場合、ターゲット側の不完全なアセットを削除し、インポート元の完全なバージョンに置き換えます。オフの場合は両方を保持します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가져오기 원본이 대상의 기존 자산에 있는 모든 파일을 포함하고 거기에 adjustment, alternate 같은 추가 역할까지 포함하는 경우, 대상의 불완전한 자산을 삭제하고 원본의 완전한 버전으로 교체합니다. 끄면 둘 다 유지합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando a fonte contém todos os arquivos de um Asset existente no destino mais funções adicionais (ajustes, alternativos), o Asset incompleto é excluído e substituído pela versão completa da fonte. Desativado: ambos são mantidos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando a origem contém todos os ficheiros de um Asset existente no destino mais funções adicionais (ajustes, alternativos), o Asset incompleto é eliminado e substituído pela versão completa da origem. Desativado: ambos são mantidos."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли джерело містить усі файли наявного Asset у цілі плюс додаткові ролі (коригування, альтернативи), неповний Asset видаляється та замінюється на повну версію з джерела. Вимкнено: обидва зберігаються."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当导入源已包含目标里某个 Asset 的全部文件、且还多出 adjustment、alternate 等额外 role 时，删除目标里那个不完整的 Asset，改用导入源的完整版本。关闭则保留两份。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當匯入來源已包含目標中某個 Asset 的全部檔案、且還多出 adjustment、alternate 等額外 role 時,刪除目標中不完整的 Asset,改用匯入來源的完整版本。關閉則保留兩份。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當匯入來源已包含目標中某個 Asset 的全部檔案、且仲多咗 adjustment、alternate 等額外 role 時,刪除目標中不完整嗰個 Asset,改用匯入來源嘅完整版本。關閉則保留兩份。"
          }
        }
      }
    },
