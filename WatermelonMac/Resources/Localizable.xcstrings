    "migration.options.skipPerceptual.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berechnet einen Wahrnehmungs-Hash für heic/jpg-Fotos aus Legacy. Wenn das Ziel dasselbe Bild bereits enthält (in irgendeinem Format), wird die Legacy-Kopie übersprungen. Der erste Scan lädt Zielfotos zum Indizieren herunter; spätere Scans nutzen den lokalen Cache."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Computes a perceptual hash for legacy heic/jpg photos. If the target already contains the same picture in any format, the legacy copy is skipped. First scan downloads target photos to index them; subsequent scans use the local cache."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula un hash perceptual para las fotos heic/jpg de legacy. Si el destino ya contiene la misma foto (en cualquier formato), se omite la copia legacy. El primer escaneo descarga las fotos del destino para indexarlas; los escaneos posteriores usan la caché local."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula un hash perceptual para las fotos heic/jpg de legacy. Si el destino ya contiene la misma foto (en cualquier formato), se omite la copia legacy. El primer escaneo descarga las fotos del destino para indexarlas; los escaneos posteriores usan la caché local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcule un hash perceptuel pour les heic/jpg legacy. Si la cible contient déjà la même photo (quel que soit le format), la copie legacy est ignorée. Le premier scan télécharge les photos cibles pour les indexer ; les scans suivants utilisent le cache local."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レガシーの heic/jpg に知覚ハッシュを計算します。ターゲットに同じ写真(任意の形式)が既にある場合、レガシーのコピーをスキップします。初回スキャンはターゲット写真をダウンロードしてインデックスを構築し、以降はローカルキャッシュを使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "레거시의 heic/jpg에 지각 해시를 계산합니다. 대상에 같은 사진(어떤 형식이든)이 이미 있으면 레거시 사본을 건너뜁니다. 첫 스캔은 대상 사진을 다운로드해 인덱싱하고, 이후 스캔은 로컬 캐시를 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula um hash perceptual para as fotos heic/jpg do legacy. Se o destino já contém a mesma foto (em qualquer formato), a cópia legacy é pulada. A primeira varredura baixa as fotos do destino para indexá-las; varreduras subsequentes usam o cache local."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calcula um hash percetual para as fotos heic/jpg do legacy. Se o destino já contém a mesma foto (em qualquer formato), a cópia legacy é ignorada. A primeira análise descarrega as fotos do destino para indexá-las; análises subsequentes usam a cache local."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обчислює перцептивний хеш для heic/jpg фото з legacy. Якщо в цілі вже є те саме фото (у будь-якому форматі), копію з legacy пропускають. Перше сканування завантажує фото з цілі для індексування; наступні сканування використовують локальний кеш."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对 legacy 里的 heic/jpg 算感知哈希。如果目标里已经有同一张照片(任意格式)，跳过 legacy 这一份。首次 scan 会下载目标照片建索引，之后命中本地缓存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對 legacy 中的 heic/jpg 算感知雜湊。若目標中已有同一張相片(任意格式)，跳過 legacy 那一份。首次掃描會下載目標相片建索引，後續掃描用本地快取。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對 legacy 入面嘅 heic/jpg 計感知雜湊。如果目標已經有同一張相(任意格式)，跳過 legacy 嗰份。第一次掃描會下載目標相片去建索引，之後用本地快取。"
          }
        }
      }
    },
