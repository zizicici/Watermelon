    "profile.add.s3.pathStyle.hint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erforderlich für MinIO und selbst gehostete S3-kompatible Server. AWS S3, Cloudflare R2 und Backblaze B2 verwenden virtuell gehostete URLs."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Required for MinIO and self-hosted S3-compatible servers. AWS S3, Cloudflare R2, and Backblaze B2 use virtual-hosted URLs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necesario para MinIO y servidores autohospedados compatibles con S3. AWS S3, Cloudflare R2 y Backblaze B2 usan URL con alojamiento virtual."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necesario para MinIO y servidores autohospedados compatibles con S3. AWS S3, Cloudflare R2 y Backblaze B2 usan URL con alojamiento virtual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requis pour MinIO et les serveurs compatibles S3 auto-hébergés. AWS S3, Cloudflare R2 et Backblaze B2 utilisent des URL de type hébergement virtuel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MinIO や自前ホストの S3 互換サーバーで必要です。AWS S3、Cloudflare R2、Backblaze B2 は virtual-hosted 形式を使います。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MinIO 및 자체 호스팅 S3 호환 서버에 필요합니다. AWS S3, Cloudflare R2, Backblaze B2는 가상 호스팅 방식 URL을 사용합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necessário para MinIO e servidores S3-compatíveis auto-hospedados. AWS S3, Cloudflare R2 e Backblaze B2 usam URLs virtual-hosted."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necessário para MinIO e servidores S3-compatíveis auto-alojados. AWS S3, Cloudflare R2 e Backblaze B2 usam URLs virtual-hosted."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Требуется для MinIO и S3-совместимых серверов, развёрнутых самостоятельно. AWS S3, Cloudflare R2 и Backblaze B2 используют URL-адреса с виртуальным хостингом."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Потрібно для MinIO та власних S3-сумісних серверів. AWS S3, Cloudflare R2 і Backblaze B2 використовують URL-адреси у форматі virtual-hosted."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MinIO 与自托管 S3 兼容服务器需要开启。AWS S3、Cloudflare R2、Backblaze B2 使用 virtual-hosted URL。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MinIO 與自架 S3 相容伺服器需要啟用。AWS S3、Cloudflare R2、Backblaze B2 使用 virtual-hosted URL。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MinIO 與自架 S3 相容伺服器需要啟用。AWS S3、Cloudflare R2、Backblaze B2 使用 virtual-hosted URL。"
          }
        }
      }
    },
