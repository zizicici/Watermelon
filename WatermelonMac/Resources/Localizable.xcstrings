    "profile.add.s3.error.writeAccess" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Prüfung des Schreibzugriffs ist mit diesen Anmeldedaten fehlgeschlagen. Prüfen Sie die Berechtigungen s3:PutObject, s3:GetObject und s3:DeleteObject für den Backup-Pfad. Grund: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The credentials failed the write-access check. Confirm s3:PutObject, s3:GetObject, and s3:DeleteObject permissions on the backup path. Reason: %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las credenciales no pueden completar la prueba de escritura. Verifica los permisos s3:PutObject, s3:GetObject y s3:DeleteObject en la ruta de copia. Motivo: %@"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las credenciales no pueden completar la prueba de escritura. Verifica los permisos s3:PutObject, s3:GetObject y s3:DeleteObject en la ruta de copia. Motivo: %@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les identifiants ne peuvent pas terminer la sonde d'écriture. Vérifiez les autorisations s3:PutObject, s3:GetObject et s3:DeleteObject sur le chemin de sauvegarde. Motif : %@"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "認証情報を使った書き込みテストに失敗しました。バックアップ先に対する s3:PutObject、s3:GetObject、s3:DeleteObject の権限を確認してください。理由：%@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자격 증명으로 쓰기 테스트를 완료할 수 없습니다. 백업 경로에서 s3:PutObject, s3:GetObject, s3:DeleteObject 권한을 확인하세요. 원인: %@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As credenciais não conseguem concluir o teste de gravação. Verifique as permissões s3:PutObject, s3:GetObject e s3:DeleteObject no caminho de backup. Motivo: %@"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As credenciais não conseguem concluir o teste de escrita. Verifique as permissões s3:PutObject, s3:GetObject e s3:DeleteObject no caminho de cópia. Motivo: %@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Учётные данные не прошли проверку записи. Убедитесь, что для пути резервного копирования предоставлены права s3:PutObject, s3:GetObject и s3:DeleteObject. Причина: %@"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Облікові дані не пройшли перевірку доступу до запису. Перевірте дозволи s3:PutObject, s3:GetObject і s3:DeleteObject для шляху резервного копіювання. Причина: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "凭证无法完成写入探测。请确认备份路径上的 s3:PutObject、s3:GetObject 和 s3:DeleteObject 权限。原因：%@"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "憑證無法完成寫入探測。請確認備份路徑上的 s3:PutObject、s3:GetObject 與 s3:DeleteObject 權限。原因：%@"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "憑證無法完成寫入探測。請確認備份路徑上的 s3:PutObject、s3:GetObject 與 s3:DeleteObject 權限。原因：%@"
          }
        }
      }
    },
